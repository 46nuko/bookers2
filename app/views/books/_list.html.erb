<div class="col-md-3">
  <h2>User info</h2>
  <>
  <table class="table">
  <tbody>
  <tr>
  </tr>
  <tr>
	  <th>name</th>
	  <th><%= user.name %></th>
  </tr>
  <tr>
	  <th>introduction</th>
	  <th><%= user.introduction %></th>
  </tr>
  </tbody>
</table>
<div class="row">
  <%= link_to 'Edit profile', edit_user_path(current_user), class: "btn btn-outline-secondary btn-block" %>
    <i class="fas fa-user-cog"></i>
</div>
      <h2 class="mt-3">New book</h2>
  <%= form_with model: book do |f| %>
  <div class="form-group">
    <label for="book_title">Title</label>
    <%= f.text_field :title %>
  </div>
  <div class="form-group">
    <label for="book_body">Opinion</label>
    <%= f.text_area :body %>
  </div>
  <div class="form-group">
    <input type="submit" name="commit" value="Create Book" class="btn btn-success" data-disable-with="Create Book">
  </div>
<% end %>
    </div>