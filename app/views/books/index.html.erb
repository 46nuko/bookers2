      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>
<div class="col-md-3">
      <h2>User info</h2>
  <tbody><tr></tr>
  <tr>
	  <th>name</th>
	  
  </tr>
  <tr>
	  <th>introduction</th>
	  
  </tr>
</tbody>
</table>
<div class="row">
  <a class="btn btn-outline-secondary btn-block edit_user_1855" href="/bookers2/users/1855/edit">
    <i class="fas fa-user-cog"></i>
</a></div>
      <h2 class="mt-3">New book</h2>
  <%= form_with model: @book do |f| %>
    <div class="form-group">
      <label for="book_title">Title</label>
      <%= f.text_field :title %>
    </div>
    <div class="form-group">
      <label for="book_body">Opinion</label>
      <%= f.text_area :body %>
    </div>
    <div class="form-group">
      <input type="submit" name="commit" value="Create Book" class="btn btn-success" data-disable-with="Create Book">
    </div>
  <% end %>
  </div>
<div class="col-md-8 offset-md-1">
  <h2>Books</h2>
  <table class="table table-hover table-inverse">
  <thead>
    <tr>
      <th></th>
      <th>Title</th>
      <th>Opinion</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
  <% @books.each do |book| %>
    <tr>
        <td><%= image_tag book.user.get_profile_image(100,100) %></td>
        <td><%= book.title %></td>
        <td><%= book.body %></td>
    </tr>
  <% end %>
  </tbody>
</table>
</div>