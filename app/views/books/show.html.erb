<%= render 'form', user:@user, book:@new_book %>
<div class="col-md-8 offset-md-1">
  <h2>Book detail</h2>
  <table class="table table-hover table-inverse">
  <thead>
    <tr>
      <th></th>
      <th>Title</th>
      <th>Opinion</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
    <tr>
        <td></td>
        <td><%= @book.title %></td>
        <td><%= @book.body %></td>
        <% if @book.user_id == Current.user.id %>
          <td><%= link_to "Edit", edit_book_path(@book) %></td>
          <td><%= link_to "Destroy", book_path(@book),  data: { turbo_method: :delete, turbo_confirm: "本当に削しますか？" } %></td>
        <% end %>
    </tr>
  </tbody>
</table>
    </div>